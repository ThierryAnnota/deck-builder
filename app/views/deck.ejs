<%- include('header') %>

<h1><%= title %></h1>

<div class="cardsContainer">

    <% cards.forEach((card) => { %>
        <div class="card">
            <img src="/visuals/<%= card.visual_name %>" alt="<%= card.name %> illustration">
            <p class="cardName"><%= card.name %></p>
            <a class="link--addCard" title="Supprimer du deck" href="/deck/delete/<%= card.id %>">[ - ]</a>
        </div>

    <% }) %>

</div>







<%- include('footer') %>